local function getDisplayName(char)
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then return hum.DisplayName end
    return char.Name
end

local function isInTeamWar()
    local myChar = lp.Character
    if not myChar then return false end
    return myChar:FindFirstChild("TEAM1") ~= nil
        or myChar:FindFirstChild("TEAM2") ~= nil
        or myChar:GetAttribute("Team") ~= nil
end

local function isSameTeam(char)
    local myChar = lp.Character
    if not myChar then return true end
    return (char:FindFirstChild("TEAM1") and myChar:FindFirstChild("TEAM1"))
        or (char:FindFirstChild("TEAM2") and myChar:FindFirstChild("TEAM2"))
        or ((char:GetAttribute("Team") and myChar:GetAttribute("Team"))
            and char:GetAttribute("Team") == myChar:GetAttribute("Team"))
end

local function getWeapon(char)
    local function scanContainer(container)
        for _, v in ipairs(container:GetDescendants()) do
            if v:IsA("Tool") or v:IsA("Model") then
                if KILLER_WEAPONS[v.Name] or VIGILANTE_WEAPONS[v.Name] then
                    return v.Name
                end
            end
        end
        return nil
    end

    local found = scanContainer(char)
    if found then return found end

    local p = Players:GetPlayerFromCharacter(char)
    if p then
        local bp = p:FindFirstChildOfClass("Backpack")
        if bp then
            found = scanContainer(bp)
            if found then return found end
        end
    end

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr.Character == char then
            local bp = plr:FindFirstChildOfClass("Backpack")
            if bp then
                found = scanContainer(bp)
                if found then return found end
            end
            break
        end
    end

    return nil
end

local function getRole(char)
    local dn = getDisplayName(char)
    if KILLER_DISPLAY_NAMES[dn] then return "Killer" end

    if isInTeamWar() then
        if isSameTeam(char) then return "Bystander" end
        return "Killer"
    end

    local weapon = getWeapon(char)
    if weapon then
        if KILLER_WEAPONS[weapon]    then return "Killer"    end
        if VIGILANTE_WEAPONS[weapon] then return "Vigilante" end
    end

    return "Bystander"
end

local function roleColor(role)
    if role == "Killer"    then return CLR_KILLER    end
    if role == "Vigilante" then return CLR_VIGILANTE end
    return CLR_BYSTANDER
end

