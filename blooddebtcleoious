local rp = RaycastParams.new()
rp.FilterType  = Enum.RaycastFilterType.Exclude
rp.IgnoreWater = true

local function setupRayParams(char)
    if not char then return end
    local filter = { char }
    local function tryAdd(name)
        local v = bf:FindFirstChild(name, true)
        if v then filter[#filter+1] = v end
    end
    tryAdd("ALWAYSHERE") tryAdd("CheckingWalking") tryAdd("INVISBARRIERS")
    tryAdd("Spawns") tryAdd("TREES") tryAdd("InvisibleWall") tryAdd("Cleaning windows")
    for _, v in next, bf:GetDescendants() do
        if v.Name:lower():find("window") then filter[#filter+1] = v end
    end
    rp.FilterDescendantsInstances = filter
end

