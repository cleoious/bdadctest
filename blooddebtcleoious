local espEnabled = false
local espObjects = {}

local function clearESP(char)
    local hl = espObjects[char]
    if hl and hl.Parent then hl:Destroy() end
    espObjects[char] = nil
end

local function applyESP(char)
    if not espEnabled then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return end

    local existing = espObjects[char]
    if existing then
        if not existing.Parent or existing.Adornee ~= char then
            existing:Destroy()
            espObjects[char] = nil
        else
            local clr = roleColor(getRole(char))
            existing.FillColor    = clr
            existing.OutlineColor = clr
            return
        end
    end

    local clr = roleColor(getRole(char))
    local hl  = Instance.new("Highlight")
    hl.Adornee             = char
    hl.FillColor           = clr
    hl.OutlineColor        = clr
    hl.FillTransparency    = 0.5
    hl.OutlineTransparency = 0
    hl.DepthMode           = Enum.HighlightDepthMode.AlwaysOnTop
    hl.Parent              = char

    espObjects[char] = hl
end

RunService.RenderStepped:Connect(function()
    if not espEnabled then
        for char in pairs(espObjects) do clearESP(char) end
        return
    end
    for _, char in next, npc:GetChildren() do
        if char == lp.Character then continue end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then
            clearESP(char)
            continue
        end
        applyESP(char)
    end
    for char in pairs(espObjects) do
        if not char.Parent then clearESP(char) end
    end
end)

