local cache = {}

local function injectActor(char)
    task.wait()
    local gun = char:FindFirstChildOfClass("Tool")
    if not gun then return end
    local actor = gun:FindFirstChild("Actor")
    if not actor then return end

    if get_actors then
        local found = false
        for _, v in next, get_actors() do
            if v == actor then found = true break end
        end
        if not found then return end
    end

    if cache[actor] then return end

    task.spawn(function()
        local retries = 0
        while retries < 100 do
            if not actor.Parent or not actor:IsDescendantOf(char) then return end
            local ok, err = pcall(run_on_actor, actor, payload)
            if ok then
                cache[actor] = true
                break
            end
            retries += 1
            task.wait(0.05)
        end
    end)
end

local charConn

local function onChar(char)
    table.clear(cache)
    if charConn then charConn:Disconnect(); charConn = nil end
    charConn = char.ChildAdded:Connect(function(child)
        if child.ClassName == "Tool" then
            task.wait()
            local actor = child:FindFirstChild("Actor")
            if actor then
                injectActor(char)
            end
        end
    end)
    local gun = char:FindFirstChildOfClass("Tool")
    if gun and gun:FindFirstChild("Actor") then
        injectActor(char)
    end
end

