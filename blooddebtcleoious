local function shouldTarget(char)
    local group = getgenv().sa_targetGroup
    if group == "All" then return true end
    local role = getRole(char)
    if group == "Killer Only" then
        return role == "Killer"
    elseif group == "Bystander + Vigilante" then
        return role == "Bystander" or role == "Vigilante"
    end
    return true
end

local function getScreenRadius()
    local vp = cam.ViewportSize
    return math.sqrt(vp.X^2 + vp.Y^2) / 2 * getgenv().sa_fovPct
end

local function getTarget(origin)
    if not getgenv().sa_enabled then return nil end

    local partName = getgenv().sa_part
    local center   = isMobile
        and Vector2.new(cam.ViewportSize.X / 2, cam.ViewportSize.Y / 2)
        or  UIS:GetMouseLocation()
    local radius   = getScreenRadius()

    local candidates = {}

    for _, char in next, npc:GetChildren() do
        if char == lp.Character then continue end
        if char:FindFirstChildOfClass("ForceField") then continue end
        local hum = char:FindFirstChild("Humanoid")
        if not hum or hum.Health <= 0 then continue end
        local pt = char:FindFirstChild("PlayerThings")
        if pt and pt:FindFirstChild("Downed") and pt.Downed.Value then continue end
        if not shouldTarget(char) then continue end

        local tPart = char:FindFirstChild(partName)
            or char:FindFirstChild("Head")
            or char.PrimaryPart
            or char:FindFirstChild("HumanoidRootPart")
        if not tPart then continue end

        local pos, onScreen = cam:WorldToViewportPoint(tPart.Position)
        if not onScreen then continue end

        local dist = (Vector2.new(pos.X, pos.Y) - center).Magnitude
        if dist > radius then continue end

        candidates[#candidates + 1] = { part = tPart, char = char, dist = dist }
    end

    if #candidates == 0 then return nil end

    local function hasGun(char)
        if char:FindFirstChildOfClass("Tool") then return true end
        local p = Players:GetPlayerFromCharacter(char)
        if p then
            local bp = p:FindFirstChildOfClass("Backpack")
            if bp and bp:FindFirstChildOfClass("Tool") then return true end
        end
        return false
    end

    local function score(c)
        local vis    = getgenv().sa_wallPrio and isVisible(c.part, origin) or true
        local armed  = hasGun(c.char)
        local visVal = vis   and 0 or 2
        local gunVal = armed and 0 or 1
        return visVal * 1000 + gunVal * 500 + c.dist
    end

    table.sort(candidates, function(a, b) return score(a) < score(b) end)

    return candidates[1].part
end

